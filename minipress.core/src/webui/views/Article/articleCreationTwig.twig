{% extends "pageSquelette.twig" %}

{% block title %}Créer un article{% endblock %}

{% block content %}
    <h1>Créer un article</h1>

    {% for message in flash.error ?? [] %}
        <p style="color:red">{{ message }}</p>
    {% endfor %}

    <form method="POST" action="{{ url_for('articleStore') }}">
        <input type="hidden" name="csrf_token" value="{{ csrf_token }}">

        <div>
            <label for="titre">Titre *</label><br>
            <input type="text" id="titre" name="titre" value="{{ old.titre ?? '' }}">
            {% if errors.titre is defined %}
                <p style="color:red">{{ errors.titre }}</p>
            {% endif %}
        </div>

        <div>
            <label for="resume">Résumé</label><br>
            <input type="text" id="resume" name="resume" value="{{ old.resume ?? '' }}">
        </div>

        <div>
            <label for="contenu">Contenu *</label><br>
            <textarea id="contenu" name="contenu" rows="8">{{ old.contenu ?? '' }}</textarea>
            {% if errors.contenu is defined %}
                <p style="color:red">{{ errors.contenu }}</p>
            {% endif %}
        </div>

        <div>
            <label for="id_categorie">Catégorie *</label><br>
            <select id="id_categorie" name="id_categorie">
                {% for categorie in categories %}
                    <option value="{{ categorie.id }}" {% if old.id_categorie is defined and old.id_categorie == categorie.id %}selected{% endif %}>
                        {{ categorie.titre }}
                    </option>
                {% endfor %}
            </select>
        </div>

        <br>

        <button type="submit">Créer</button>
        <a href="{{ url_for('home') }}">Annuler</a>
    </form>
{% endblock %}