{% extends "pageSquelette.twig" %}

{% block head %}
    <title>Catégorie - {{ categorie.titre }}</title>
{% endblock %}

{% block content %}

    <h1>Les articles de {{ categorie.titre }}</h1>
    <div id="grilleArticles">
        {% for a in articles %}
            <h2>{{a.titre}}</h2>
            <p><em>{{a.date}}</em></p>
            {% if a.resume != null %}
                <p>{{a.resume}}</p>
            {% endif %}
            <a href="{{ url_for('oneArticle', { id: a.id }) }}">Lire la suite</a>
        {% endfor %}
    </div>

    </br><a href="{{ url_for('allCategories') }}">Toutes les catégories</a>
{% endblock %}