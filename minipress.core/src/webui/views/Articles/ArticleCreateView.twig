{% extends "TemplateView.twig" %}

{% block title %}Créer un article{% endblock %}

{% block content %}
    <section class="form">
        <h2>Créer un article</h2>

        {% for message in flash.error ?? [] %}
            <p style="color:red">{{ message }}</p>
        {% endfor %}

        <form method="POST" action="{{ url_for('ArticleStore') }}">
            <input type="hidden" name="csrf_token" value="{{ csrf_token }}">

            <div>
                <label for="titre">Titre *</label>
                <input type="text" id="titre" name="titre" value="{{ old.titre ?? '' }}">
                {% if errors.titre is defined %}
                    <p style="color:red">{{ errors.titre }}</p>
                {% endif %}
            </div>

            <div>
                <label for="resume">Résumé</label>
                <textarea id="resume" name="resume" rows="2" placeholder="Format Markdown attendu">{{ old.resume ?? '' }}</textarea>
            </div>

            <div>
                <label for="contenu">Contenu *</label>
                <textarea id="contenu" name="contenu" rows="8" placeholder="Format Markdown attendu">{{ old.contenu ?? '' }}</textarea>
                {% if errors.contenu is defined %}
                    <p style="color:red">{{ errors.contenu }}</p>
                {% endif %}
            </div>

            <div>
                <label for="id_categorie">Catégorie *</label>
                <select id="id_categorie" name="id_categorie">
                    {% for categorie in categories %}
                        <option value="{{ categorie.id }}" {% if old.id_categorie is defined and old.id_categorie == categorie.id %}selected{% endif %}>
                            {{ categorie.titre }}
                        </option>
                    {% endfor %}
                </select>
            </div>


            <div>
                <label for="image">Image</label>
                <textarea id="image" name="image" rows="2" placeholder="url1,url2,url3">{{ old.image ?? '' }}</textarea>
            </div>

            
            <div>
                <button type="submit">Créer</button>
                <a href="{{ url_for('home') }}">Annuler</a>
            </div>
        </form>
    </section>
{% endblock %}