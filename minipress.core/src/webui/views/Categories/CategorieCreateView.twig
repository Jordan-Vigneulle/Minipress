{% extends "TemplateView.twig" %}

{% block title %}Créer une catégorie{% endblock %}

{% block content %}
    <section class="form">
        <h2>Créer une catégorie</h2>

        <form method="POST" action="{{ url_for('CategorieStore') }}">

            <div>
                <label for="titre">Titre *</label>
                <input type="text" id="titre" name="titre">
            </div>
            
            <div>
                <button type="submit">Créer</button>
                <a href="{{ url_for('home') }}">Annuler</a>
            </div>
        </form>
    </section>
{% endblock %}