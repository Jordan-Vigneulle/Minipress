{% extends "pageSquelette.twig" %}

{% block head %}
    <title>Article - {{ article.titre }}</title>
{% endblock %}

{% block content %}
    <h1>{{ article.titre }}</h1>
    <em>{{ date }}</em>

    <div class="galerie">
        {% for img in article.images %}
            <img src="{{ img.url }}" alt="{{ article.titre }}">
        {% endfor %}
    </div>

    <p>{{ contenuHTML|raw }}</p>
    
    <a href="{{ url_for('allArticlesByCategorie', { id: article.categorie.id }) }}">Voir les autres article de {{ article.categorie.titre }}</a>
{% endblock %}